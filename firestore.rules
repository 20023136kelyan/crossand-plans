rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    } 

    function isPlanHost(planId, userId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.hostId == userId;
    }

    function isPlanInvitedParticipant(planId, userId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.invitedParticipantUserIds != null && userId in planData.invitedParticipantUserIds;
    }

    function isPlanParticipant(planId, userId) {
      return isPlanHost(planId, userId) || isPlanInvitedParticipant(planId, userId);
    }

    function isPlanPast(planId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.eventTime < request.time;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection (User Profiles) ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'handled', 'status', 'readAt']);
        allow delete: if isAdmin();
        allow create: if false;
      }

      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /friendships/{friendId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // --- User Stats Collection ---
    match /userStats/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    // --- User Notification Preferences Collection ---
    match /userNotificationPreferences/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // --- User Security Collection (for 2FA) ---
    match /userSecurity/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
                       request.auth.uid in request.resource.data.participants &&
                       request.resource.data.participants.size() > 0 &&
                       request.resource.data.type != null &&
                       request.resource.data.participantInfo.size() == request.resource.data.participants.size() &&
                       (
                         (request.resource.data.type == 'direct' && request.resource.data.participants.size() == 2) ||
                         request.resource.data.type == 'group'
                       );
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants &&
                  (
                    // Case 1: Sending a message
                    (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['lastMessageText', 'lastMessageSenderId', 'lastMessageTimestamp', 'updatedAt', 'participantReadTimestamps']) &&
                      request.resource.data.lastMessageSenderId == request.auth.uid &&
                      request.resource.data.lastMessageTimestamp == request.time &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.participantReadTimestamps[request.auth.uid] == request.time &&
                      (
                        (!('participantReadTimestamps' in resource.data) &&
                          request.resource.data.participantReadTimestamps.keys().toSet().hasOnly([request.auth.uid])
                        ) ||
                        (
                          ('participantReadTimestamps' in resource.data) &&
                          // MODIFIED: Replaced subsetOf with equivalent logic
                          resource.data.participantReadTimestamps.keys().toSet()
                            .difference(request.resource.data.participantReadTimestamps.keys().toSet()).size() == 0 &&
                          request.resource.data.participantReadTimestamps.keys().toSet()
                            .difference(resource.data.participantReadTimestamps.keys().toSet())
                            .hasOnly([request.auth.uid])
                        )
                      )
                    ) ||
                    // Case 2: Marking chat as read
                    (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['participantReadTimestamps', 'updatedAt']) &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.participantReadTimestamps[request.auth.uid] == request.time &&
                      request.resource.data.participantReadTimestamps.diff(resource.data.participantReadTimestamps).affectedKeys()
                        .hasOnly([request.auth.uid])
                    )
                  );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          (
            (request.resource.data.text != null && request.resource.data.text.size() > 0) ||
            (request.resource.data.mediaUrl != null && request.resource.data.mediaUrl.size() > 0)
          ) &&
          request.resource.data.timestamp == request.time &&
          // Validate reply structure if present
          (
            !('replyTo' in request.resource.data) ||
            (
              'replyTo' in request.resource.data &&
              'messageId' in request.resource.data.replyTo &&
              'senderId' in request.resource.data.replyTo &&
              exists(/databases/$(database)/documents/chats/$(chatId)/messages/$(request.resource.data.replyTo.messageId))
            )
          ) &&
          // Validate thread metadata if present
          (
            !('threadId' in request.resource.data) ||
            (
              'threadId' in request.resource.data &&
              'parentId' in request.resource.data &&
              'lineage' in request.resource.data &&
              exists(/databases/$(database)/documents/chats/$(chatId)/messages/$(request.resource.data.threadId)) &&
              exists(/databases/$(database)/documents/chats/$(chatId)/messages/$(request.resource.data.parentId)) &&
              request.resource.data.lineage is list &&
              request.resource.data.lineage.hasAny([request.resource.data.threadId]) &&
              request.resource.data.lineage.hasAny([request.resource.data.parentId]) &&
              (
                !exists(/databases/$(database)/documents/chats/$(chatId)/messages/$(request.resource.data.threadId)) ||
                (
                  (request.resource.data.threadId == request.resource.data.parentId) == 
                  (request.resource.data.get('isThreadRoot', false) == true)
                )
              )
            )
          ) &&
          // If this is a reply, ensure thread metadata is consistent with replyTo
          (
            !('replyTo' in request.resource.data) ||
            !('threadId' in request.resource.data) ||
            (
              get(/databases/$(database)/documents/chats/$(chatId)/messages/$(request.resource.data.replyTo.messageId)).data.threadId == request.resource.data.threadId ||
              (
                request.resource.data.threadId == request.resource.data.replyTo.messageId &&
                request.resource.data.parentId == request.resource.data.replyTo.messageId
              )
            )
          );

        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (
            // Case 1: Allow updating hiddenBy field
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hiddenBy']) &&
              request.resource.data.hiddenBy.hasAll(resource.data.hiddenBy) &&
              request.resource.data.hiddenBy.removeAll(resource.data.hiddenBy).hasOnly([request.auth.uid])
            ) ||
            // Case 2: Allow updating readBy and status fields for read receipts
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'status', 'updatedAt']) &&
              request.resource.data.updatedAt == request.time &&
              request.resource.data.readBy.diff(resource.data.readBy).affectedKeys().hasOnly([request.auth.uid]) &&
              (resource.data.status == 'sent' || resource.data.status == null) &&
              request.resource.data.status == 'read'
            ) ||
            // Case 3: Allow updating thread metadata
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastThreadActivity', 'threadCount', 'lastThreadMessagePreview', 'updatedAt']) &&
              request.resource.data.updatedAt == request.time &&
              (resource.data.senderId == request.auth.uid || isAdmin()) &&
              ('threadId' in resource.data) &&
              ('isThreadRoot' in resource.data) &&
              resource.data.isThreadRoot == true &&
              (request.resource.data.threadCount == resource.data.threadCount + 1 || request.resource.data.threadCount == resource.data.threadCount) &&
              ('lastThreadMessagePreview' in request.resource.data) &&
              ('senderId' in request.resource.data.lastThreadMessagePreview) &&
              ('timestamp' in request.resource.data.lastThreadMessagePreview) &&
              (request.resource.data.lastThreadMessagePreview.timestamp == request.time)
            )
          );
        allow delete: if false;
      }

      // Typing indicators subcollection
      match /typing/status {
        allow read: if isSignedIn() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
          
        allow create: if isSignedIn() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data[request.auth.uid] != null &&
          request.resource.data[request.auth.uid].name != null &&
          request.resource.data[request.auth.uid].timestamp != null &&
          request.resource.data.keys().hasOnly([request.auth.uid]);
          
        allow update: if isSignedIn() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (request.resource.data[request.auth.uid] != null || !(request.auth.uid in request.resource.data)) &&
          (request.resource.data.keys().hasOnly([request.auth.uid]) || request.resource.data.keys().hasOnly([]));
          
        allow delete: if false;
      }
    }

    // --- Plans Collection ---
    match /plans/{planId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (
          resource.data.hostId == request.auth.uid
        ) ||
        (
          resource.data.hostId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
          request.resource.data.status == 'completed' &&
          request.resource.data.updatedAt == request.time
        ) ||
        (
          isPlanParticipant(planId, request.auth.uid) &&
          resource.data.status == 'completed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completionConfirmedBy', 'updatedAt']) &&
          request.resource.data.completionConfirmedBy.hasAll(resource.data.completionConfirmedBy) &&
          request.resource.data.completionConfirmedBy.removeAll(resource.data.completionConfirmedBy).hasOnly([request.auth.uid]) &&
          request.resource.data.updatedAt == request.time
        ) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || isAdmin()
      );

      match /ratings/{ratingUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == ratingUserId &&
                       isPlanParticipant(planId, request.auth.uid) &&
                       isPlanPast(planId) &&
                       request.resource.data.value >= 1 && request.resource.data.value <= 5 &&
                       request.resource.data.createdAt == request.time &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.planId == planId;
        allow delete: if isSignedIn() && request.auth.uid == ratingUserId &&
                        isPlanParticipant(planId, request.auth.uid) &&
                        isPlanPast(planId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid &&
                        isPlanParticipant(planId, request.auth.uid) &&
                        request.resource.data.text.size() > 0 &&
                        request.resource.data.createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt']) &&
                       request.resource.data.text.size() > 0 &&
                       request.resource.data.updatedAt == request.time;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }
    
    // Plan Shares Collection
    match /planShares/{shareId} {
      allow read: if isSignedIn() && 
                   (request.auth.uid == resource.data.sharedWithUid || 
                    request.auth.uid == resource.data.sharedByUid);
      allow create: if isSignedIn() && 
                     request.auth.uid == request.resource.data.sharedByUid &&
                     request.resource.data.status == 'pending';
      allow update: if isSignedIn() && 
                     request.auth.uid == resource.data.sharedWithUid &&
                     resource.data.status == 'pending' &&
                     (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined') &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                     request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }
    
    // PlanCollections rules
    match /planCollections/{collectionId} {
      allow read: if true;
      allow write: if false;
    }

    // Feed Posts Collection
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.text.size() > 0 &&
                         request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // --- Subscriptions Collection ---
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }
  }
}
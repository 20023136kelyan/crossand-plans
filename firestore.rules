rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    } 

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlanHost(planId, userId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.hostId == userId;
    }

    function isPlanInvitedParticipant(planId, userId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.invitedParticipantUserIds != null && userId in planData.invitedParticipantUserIds;
    }

    function isPlanParticipant(planId, userId) {
      return isPlanHost(planId, userId) || isPlanInvitedParticipant(planId, userId);
    }

    function isPlanPast(planId) {
      let planData = get(/databases/$(database)/documents/plans/$(planId)).data;
      return planData != null && planData.eventTime < request.time;
    }

    function isFeedPostOwner(postId, userId) {
      let postData = get(/databases/$(database)/documents/feedPosts/$(postId)).data;
      return postData != null && postData.userId == userId;
    }

    function isFriendOf(userId1, userId2) {
      let friendship1 = get(/databases/$(database)/documents/users/$(userId1)/friendships/$(userId2)).data;
      let friendship2 = get(/databases/$(database)/documents/users/$(userId2)/friendships/$(userId1)).data;
      return friendship1 != null && friendship1.status == 'friends' &&
             friendship2 != null && friendship2.status == 'friends';
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection (User Profiles) ---
    // Users can read and write their own profile data
    // Admins can read and write all user profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      // Allow users to read/write their own notifications, restrict updates, and allow only admin deletes
      match /notifications/{notificationId} {
        // Allow users to read their own notifications
        allow read: if request.auth != null && request.auth.uid == userId;

        // Allow users to update only isRead, handled, status, and readAt fields
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'handled', 'status', 'readAt']);

        // Allow backend/admin to delete notifications (for cleanup)
        allow delete: if isAdmin();

        // Prevent users from creating or deleting notifications directly
        allow create: if false;
      }
      // Allow users to read/write their own FCM tokens
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /friendships/{friendId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // --- User Stats Collection ---
    // Stats are read by users and admins, but only written by system/admins
    // This prevents users from manipulating their own stats
    match /userStats/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only admins and system can write to stats
      allow write: if isAdmin();
    }
    
    // --- User Notification Preferences Collection ---
    // Users can read and write their own notification preferences
    // Admins can read all preferences for support purposes
    match /userNotificationPreferences/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // --- User Security Collection (for 2FA) ---
    // Users can read their own security settings
    // Only admins can write to prevent security bypasses
    // 2FA operations should go through secure API endpoints
    match /userSecurity/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only allow reads by the user, writes should go through the API for security
      allow write: if isAdmin();
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
                       request.auth.uid in request.resource.data.participants &&
                       request.resource.data.participants.size() > 0 &&
                       request.resource.data.type != null &&
                       request.resource.data.participantInfo.size() == request.resource.data.participants.size() &&
                       (
                         (request.resource.data.type == 'direct' && request.resource.data.participants.size() == 2) ||
                         request.resource.data.type == 'group'
                       );
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants &&
                  (
                    // Case 1: Sending a message
                    (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['lastMessageText', 'lastMessageSenderId', 'lastMessageTimestamp', 'updatedAt', 'participantReadTimestamps']) &&
                      request.resource.data.lastMessageSenderId == request.auth.uid &&
                      request.resource.data.lastMessageTimestamp == request.time &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.participantReadTimestamps[request.auth.uid] == request.time &&
                      (
                        (!('participantReadTimestamps' in resource.data) &&
                          request.resource.data.participantReadTimestamps.keys().toSet().hasOnly([request.auth.uid])
                        ) ||
                        (
                          ('participantReadTimestamps' in resource.data) &&
                          resource.data.participantReadTimestamps.keys().toSet()
                            .subsetOf(request.resource.data.participantReadTimestamps.keys().toSet()) &&
                          request.resource.data.participantReadTimestamps.keys().toSet()
                            .difference(resource.data.participantReadTimestamps.keys().toSet())
                            .hasOnly([request.auth.uid])
                        )
                      )
                    ) ||
                    // Case 2: Marking chat as read
                    (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['participantReadTimestamps', 'updatedAt']) &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.participantReadTimestamps[request.auth.uid] == request.time &&
                      request.resource.data.participantReadTimestamps.diff(resource.data.participantReadTimestamps).affectedKeys()
                        .hasOnly([request.auth.uid])
                    )
                  );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          (
            (request.resource.data.text != null && request.resource.data.text.size() > 0) ||
            (request.resource.data.mediaUrl != null && request.resource.data.mediaUrl.size() > 0)
          ) &&
          request.resource.data.timestamp == request.time;
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hiddenBy']) &&
          request.resource.data.hiddenBy.hasAll(resource.data.hiddenBy) &&
          request.resource.data.hiddenBy.removeAll(resource.data.hiddenBy).hasOnly([request.auth.uid]);
        allow delete: if false;
      }
    }

    // --- Plans Collection ---
    match /plans/{planId} {
      allow read: if true; // Public read access
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (
          // Host can update their plan
          resource.data.hostId == request.auth.uid
        ) ||
        (
          // Host can mark plan as completed after event time
          resource.data.hostId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'completed' &&
          request.resource.data.updatedAt == request.time
        ) ||
        (
          // Participants can confirm completion
          isPlanParticipant(planId, request.auth.uid) &&
          resource.data.status == 'completed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completionConfirmedBy', 'updatedAt']) &&
          request.resource.data.completionConfirmedBy.hasAll(resource.data.completionConfirmedBy) &&
          request.resource.data.completionConfirmedBy.removeAll(resource.data.completionConfirmedBy).hasOnly([request.auth.uid]) &&
          request.resource.data.updatedAt == request.time
        ) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || isAdmin()
      );

      match /ratings/{ratingUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == ratingUserId &&
                       isPlanParticipant(planId, request.auth.uid) &&
                       isPlanPast(planId) &&
                       request.resource.data.value >= 1 && request.resource.data.value <= 5 &&
                       request.resource.data.createdAt == request.time &&
                       request.resource.data.userId == request.auth.uid && // Check if userId in data matches auth
                       request.resource.data.planId == planId; // Check if planId in data matches current plan
        allow delete: if isSignedIn() && request.auth.uid == ratingUserId &&
                        isPlanParticipant(planId, request.auth.uid) &&
                        isPlanPast(planId);
      }

      match /comments/{commentId} {
        allow read: if true; // Comments are public
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid &&
                        isPlanParticipant(planId, request.auth.uid) &&
                        request.resource.data.text.size() > 0 &&
                        request.resource.data.createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId && // Owner can edit their comment
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt']) &&
                       request.resource.data.text.size() > 0 &&
                       request.resource.data.updatedAt == request.time;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId; // Owner can delete their comment
      }
    }
    
    // Plan Shares Collection
    match /planShares/{shareId} {
      allow read: if isSignedIn() && 
                   (request.auth.uid == resource.data.sharedWithUid || 
                    request.auth.uid == resource.data.sharedByUid);
      allow create: if isSignedIn() && 
                     request.auth.uid == request.resource.data.sharedByUid &&
                     request.resource.data.status == 'pending';
      allow update: if isSignedIn() && 
                     request.auth.uid == resource.data.sharedWithUid &&
                     resource.data.status == 'pending' &&
                     (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined') &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                     request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }
    
    // PlanCollections rules
    match /planCollections/{collectionId} {
      allow read: if true;
      allow write: if false;
    }

    // Feed Posts Collection
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.text.size() > 0 &&
                         request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // --- Subscriptions Collection ---
    // Users can read their own subscription data
    // Only admins can write to prevent subscription manipulation
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Only admins can write to subscriptions
      allow write: if isAdmin();
    }
  }
}

